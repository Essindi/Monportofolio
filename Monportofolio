<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="description" content="Portfolio d'Eugène Salomon — Développeur Web & Analyste de données" />
<title>Eugène Salomon · Développeur Web</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
<style>
  :root {
    --ink: #0e0e10;
    --paper: #f5f0e8;
    --cream: #ede8db;
    --accent: #b8540a;
    --accent2: #1a4a3a;
    --gold: #c8963e;
    --muted: #7a7468;
    --line: rgba(14,14,16,0.12);
    --radius: 2px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: 'DM Mono', monospace;
    font-weight: 300;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ───────────── NOISE OVERLAY ───────────── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 180px;
    pointer-events: none;
    z-index: 9999;
    opacity: .5;
  }

  /* ───────────── SCROLLBAR ───────────── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--cream); }
  ::-webkit-scrollbar-thumb { background: var(--accent); }

  /* ───────────── UTILITY ───────────── */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 3rem); }
  .tag { font-family: 'DM Mono', monospace; font-size: .65rem; letter-spacing: .12em; text-transform: uppercase; background: var(--ink); color: var(--paper); padding: .25rem .6rem; border-radius: var(--radius); display: inline-block; }
  .tag.light { background: var(--paper); color: var(--ink); border: 1px solid var(--line); }
  .tag.accent { background: var(--accent); }

  /* ───────────── NAV ───────────── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 1rem clamp(1.25rem, 5vw, 3rem);
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(245,240,232,.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
    transition: background .3s;
  }
  .nav-logo {
    font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1rem;
    letter-spacing: -.02em; color: var(--ink); text-decoration: none;
  }
  .nav-logo span { color: var(--accent); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    font-family: 'DM Mono', monospace; font-size: .72rem;
    letter-spacing: .1em; text-transform: uppercase;
    color: var(--muted); text-decoration: none;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--accent); }
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
  .hamburger span { display: block; width: 24px; height: 1.5px; background: var(--ink); transition: .3s; }
  .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  @media (max-width: 640px) {
    .hamburger { display: flex; }
    .nav-links {
      display: none; flex-direction: column; gap: 0;
      position: absolute; top: 100%; left: 0; right: 0;
      background: var(--paper);
      border-bottom: 1px solid var(--line);
      padding: 1rem 0;
    }
    .nav-links.open { display: flex; }
    .nav-links a { padding: .75rem clamp(1.25rem, 5vw, 3rem); display: block; }
  }

  /* ───────────── HERO ───────────── */
  #hero {
    min-height: 100svh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
    padding-top: 80px;
  }

  .hero-text { padding: clamp(2rem, 6vw, 5rem) 0; }

  .hero-eyebrow {
    display: flex; align-items: center; gap: .75rem;
    margin-bottom: 1.5rem; opacity: 0;
    animation: fadeUp .6s .1s ease forwards;
  }
  .hero-eyebrow::before {
    content: ''; display: block; width: 40px; height: 1px; background: var(--accent);
  }

  .hero-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 300; line-height: .95;
    letter-spacing: -.02em;
    margin-bottom: 1.25rem;
    opacity: 0; animation: fadeUp .7s .2s ease forwards;
  }
  .hero-name em { font-style: italic; color: var(--accent); }

  .hero-title {
    font-family: 'Syne', sans-serif; font-weight: 600;
    font-size: clamp(.85rem, 2vw, 1.05rem);
    letter-spacing: .05em; text-transform: uppercase;
    color: var(--accent2); margin-bottom: 1.5rem;
    opacity: 0; animation: fadeUp .7s .3s ease forwards;
  }

  .hero-desc {
    font-size: clamp(.82rem, 1.8vw, .95rem);
    color: var(--muted); max-width: 44ch;
    line-height: 1.8; margin-bottom: 2.5rem;
    opacity: 0; animation: fadeUp .7s .4s ease forwards;
  }

  .hero-cta {
    display: flex; flex-wrap: wrap; gap: 1rem;
    opacity: 0; animation: fadeUp .7s .5s ease forwards;
  }
  .btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .75rem 1.75rem;
    font-family: 'DM Mono', monospace; font-size: .75rem;
    letter-spacing: .08em; text-transform: uppercase;
    text-decoration: none; border-radius: var(--radius);
    transition: transform .2s, box-shadow .2s, background .2s;
    cursor: pointer; border: none;
  }
  .btn-primary { background: var(--ink); color: var(--paper); }
  .btn-primary:hover { background: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(184,84,10,.3); }
  .btn-outline { background: transparent; color: var(--ink); border: 1px solid var(--ink); }
  .btn-outline:hover { background: var(--ink); color: var(--paper); transform: translateY(-2px); }

  /* Photo frame */
  .hero-visual {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; animation: fadeIn .9s .3s ease forwards;
  }

  .photo-frame {
    position: relative;
    width: min(380px, 100%);
    aspect-ratio: 3/4;
    border-radius: 4px;
    overflow: hidden;
  }
  .photo-frame::before {
    content: '';
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(160deg, transparent 50%, rgba(14,14,16,.35));
  }
  .photo-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #1a4a3a 0%, #0e2a20 40%, #b8540a 100%);
    display: flex; align-items: flex-end;
    padding: 2rem;
  }
  .photo-placeholder-inner {
    color: rgba(255,255,255,.9);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem; line-height: 1.3;
  }
  .photo-placeholder-inner span {
    display: block; font-size: .7rem;
    font-family: 'DM Mono', monospace;
    letter-spacing: .1em; opacity: .7; margin-bottom: .25rem;
  }

  /* Decorative deco behind frame */
  .photo-deco {
    position: absolute;
    width: min(380px, 100%); aspect-ratio: 3/4;
    border: 1px solid var(--accent);
    border-radius: 4px;
    top: 18px; left: 18px;
    z-index: -1;
  }

  .hero-stats {
    position: absolute; bottom: -1.5rem; left: -1.5rem;
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 1rem 1.5rem;
    box-shadow: 4px 4px 0 var(--accent);
    z-index: 2;
  }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem; font-weight: 600;
    line-height: 1; color: var(--accent);
  }
  .stat-label {
    font-size: .65rem; letter-spacing: .1em;
    text-transform: uppercase; color: var(--muted);
  }

  @media (max-width: 760px) {
    #hero { grid-template-columns: 1fr; gap: 2rem; }
    .hero-visual { order: -1; }
    .photo-frame { width: min(280px, 75vw); margin: 0 auto; }
    .photo-deco { left: calc(50% - min(280px, 75vw)/2 + 12px); top: 12px; width: min(280px, 75vw); }
    .hero-stats { bottom: -1rem; left: calc(50% - min(280px, 75vw)/2); }
    .hero-text { padding: 1rem 0 3rem; }
    .hero-desc { max-width: 100%; }
  }

  /* ───────────── SECTION SHARED ───────────── */
  section { padding: clamp(4rem, 10vw, 7rem) 0; }

  .section-header {
    display: flex; align-items: baseline; gap: 1.5rem;
    margin-bottom: 3rem; flex-wrap: wrap;
  }
  .section-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem; font-weight: 300;
    color: var(--line); line-height: 1;
  }
  .section-title {
    font-family: 'Syne', sans-serif; font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    letter-spacing: -.03em; line-height: 1.1;
  }
  .section-title span { color: var(--accent); }

  /* ───────────── ABOUT ───────────── */
  #about { background: var(--cream); }
  .about-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: start; }

  .about-quote {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-style: italic; line-height: 1.4;
    color: var(--ink); font-weight: 300;
    padding-left: 1.5rem;
    border-left: 3px solid var(--accent);
  }

  .about-body { font-size: .88rem; line-height: 2; color: var(--muted); }
  .about-body p + p { margin-top: 1rem; }

  .skills-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: .75rem; margin-top: 2rem;
  }
  .skill-item {
    display: flex; align-items: center; gap: .6rem;
    font-size: .75rem; letter-spacing: .05em;
  }
  .skill-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }

  @media (max-width: 760px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
    .skills-grid { grid-template-columns: 1fr 1fr; }
  }

  /* ───────────── PROJECTS ───────────── */
  #projects {}
  .projects-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

  .project-card {
    border: 1px solid var(--line); padding: 2.5rem;
    position: relative; overflow: hidden;
    border-radius: var(--radius);
    transition: transform .3s, box-shadow .3s;
    background: var(--paper);
  }
  .project-card::after {
    content: ''; position: absolute;
    bottom: 0; left: 0; right: 0; height: 3px;
    background: var(--accent); transform: scaleX(0); transform-origin: left;
    transition: transform .35s ease;
  }
  .project-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(14,14,16,.08); }
  .project-card:hover::after { transform: scaleX(1); }

  .project-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.5rem; font-weight: 300;
    color: var(--cream); line-height: 1;
    margin-bottom: .5rem; user-select: none;
  }
  .project-title {
    font-family: 'Syne', sans-serif; font-weight: 700;
    font-size: clamp(.9rem, 2vw, 1.1rem);
    letter-spacing: -.01em; margin-bottom: .75rem;
    text-transform: uppercase; line-height: 1.3;
  }
  .project-desc { font-size: .8rem; line-height: 1.9; color: var(--muted); margin-bottom: 1.5rem; }
  .project-tags { display: flex; flex-wrap: wrap; gap: .4rem; }

  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: 1fr; }
    .project-card { padding: 1.75rem; }
  }

  /* ───────────── REALISATIONS ───────────── */
  #realisations { background: var(--cream); }
  .real-list { display: flex; flex-direction: column; gap: 0; }
  .real-item {
    display: grid; grid-template-columns: 3rem 1fr auto;
    align-items: center; gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--line);
    transition: background .2s;
  }
  .real-item:last-child { border-bottom: none; }
  .real-index {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; color: var(--muted); font-weight: 300;
  }
  .real-text { font-family: 'Syne', sans-serif; font-size: clamp(.82rem, 2vw, .95rem); font-weight: 600; letter-spacing: -.01em; }
  .real-arrow { color: var(--accent); font-size: 1.2rem; }

  /* ───────────── CONTACT ───────────── */
  #contact {
    background: var(--ink); color: var(--paper);
    position: relative; overflow: hidden;
  }
  #contact::before {
    content: 'HELLO';
    position: absolute; right: -2rem; top: 50%; transform: translateY(-50%);
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(8rem, 18vw, 18rem); font-weight: 300;
    color: rgba(255,255,255,.03); line-height: 1;
    user-select: none; pointer-events: none; white-space: nowrap;
  }
  .contact-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: center; }

  .contact-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 300; line-height: 1.1;
    letter-spacing: -.03em;
  }
  .contact-heading em { font-style: italic; color: var(--gold); }

  .contact-info { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-item { display: flex; align-items: center; gap: 1rem; }
  .contact-icon {
    width: 42px; height: 42px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,.15);
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; flex-shrink: 0;
  }
  .contact-detail span { display: block; font-size: .65rem; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: .2rem; }
  .contact-detail a, .contact-detail p {
    color: var(--paper); font-size: .88rem;
    text-decoration: none;
    transition: color .2s;
  }
  .contact-detail a:hover { color: var(--gold); }

  @media (max-width: 760px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  /* ───────────── FOOTER ───────────── */
  footer {
    background: var(--ink); color: rgba(255,255,255,.35);
    border-top: 1px solid rgba(255,255,255,.06);
    padding: 1.5rem clamp(1.25rem, 5vw, 3rem);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
    font-size: .7rem; letter-spacing: .08em; text-transform: uppercase;
  }
  footer span { color: var(--gold); }

  /* ───────────── ANIMATIONS ───────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .reveal {
    opacity: 0; transform: translateY(28px);
    transition: opacity .65s ease, transform .65s ease;
  }
  .reveal.visible { opacity: 1; transform: none; }

  /* ───────────── USER PHOTO UPLOAD ───────────── */
  .photo-upload-hint {
    position: absolute; top: .75rem; right: .75rem; z-index: 10;
  }
  #photo-input { display: none; }
  .upload-btn {
    background: rgba(245,240,232,.9); border: 1px solid var(--line);
    color: var(--ink); cursor: pointer;
    font-family: 'DM Mono', monospace; font-size: .65rem;
    letter-spacing: .08em; padding: .35rem .7rem;
    text-transform: uppercase; border-radius: var(--radius);
    backdrop-filter: blur(4px);
    transition: background .2s;
  }
  .upload-btn:hover { background: var(--accent); color: var(--paper); border-color: var(--accent); }
  #user-photo { width: 100%; height: 100%; object-fit: cover; display: none; }

  /* decorative line separator */
  .divider { width: 3rem; height: 2px; background: var(--accent); display: block; margin: 1.5rem 0; }
</style>
</head>
