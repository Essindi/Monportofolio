<!-- ══════════ PROJECTS ══════════ -->
<section id="projects">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-num">02</span>
      <h2 class="section-title">Projets <span>phares</span></h2>
    </div>
    <div class="projects-grid">

